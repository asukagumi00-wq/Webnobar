{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hanz-nobar",
  "main": "src/index.js",
  "compatibility_date": "2026-07-12",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/ws"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "NOBAR_ROOM",
        "class_name": "NobarRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["NobarRoom"]
    }
  ]
}
